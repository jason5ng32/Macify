# Copy to .env.local (gitignored) to override locally.
#
# Donate prompt interval in milliseconds. Defaults to 30 days when unset.
# Useful values for testing:
#   10000      -> 10 seconds
#   60000      -> 1 minute
#   3600000    -> 1 hour
#   86400000   -> 1 day
#   2592000000 -> 30 days (production default)
#
# VITE_DONATE_INTERVAL_MS=60000
