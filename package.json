{
  "name": "macify",
  "version": "2.2.0",
  "private": true,
  "description": "Transform Safari or Chrome's new tab into a macOS aerial screensaver.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode chrome",
    "build:safari": "vite build --mode safari && node scripts/prepare-safari-dist.mjs",
    "package:safari": "npm run build:safari && xcrun safari-web-extension-packager dist --macos-only",
    "preview": "vite preview",
    "zip": "node scripts/zip.js",
    "build:quotes": "node scripts/build-quotes.mjs",
    "build:videos": "node scripts/build-videos.mjs",
    "download:aerials": "cd scripts && python3 -m aerial_downloader.main"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@iconify/json": "^2.2.469",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "suncalc": "^1.9.0"
  }
}
